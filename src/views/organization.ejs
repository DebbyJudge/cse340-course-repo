<%- include('partials/header') %>

<main>

    <h1><%= title %></h1>

    <h2><%= organizationDetails.name %></h2>

    <img
        src="/images/<%= organizationDetails.logo_filename %>"
        alt="<%= organizationDetails.name %> logo">

    <p>
        <strong>Description:</strong>
        <%= organizationDetails.description %>
    </p>

    <p>
        <strong>Email:</strong>
        <%= organizationDetails.contact_email %>
    </p>

    <h3>Service Projects</h3>

    <ul>

        <% projects.forEach(project => { %>

            <li>
                <a href="/project/<%= project.project_id %>">
                    <%= project.title %>
                </a>
            </li>

        <% }) %>

    </ul>

</main>

<%- include('partials/footer') %>